---
/*
  LineIcon — thin-line robotics diagram / annotation motifs.
  Drawn as engineering line-work, not clip art: single stroke weight,
  no fill, inherits `currentColor` so the parent sets orange or blue.

  Names:
    gripper · frustum · field · spark          (focus-area icons)
    statemachine · node · trajectory · arm     (field-note thumbnails)
    coordframe                                 (decorative annotation)
*/
interface Props {
  name:
    | 'gripper'
    | 'frustum'
    | 'field'
    | 'spark'
    | 'statemachine'
    | 'node'
    | 'trajectory'
    | 'arm'
    | 'coordframe';
  class?: string;
  label?: string;
}
const { name, class: klass, label } = Astro.props;
const a11y = label
  ? { role: 'img' as const, 'aria-label': label }
  : { 'aria-hidden': 'true' as const };
---

<svg
  viewBox="0 0 48 48"
  fill="none"
  stroke="currentColor"
  stroke-width="1.25"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['line-icon', klass]}
  {...a11y}
>
  {name === 'gripper' && (
    <>
      <path d="M14 10h20" />
      <path d="M24 10v6" />
      <path d="M18 16v14h4" />
      <path d="M30 16v14h-4" />
      <circle cx="24" cy="34" r="5" />
    </>
  )}

  {name === 'frustum' && (
    <>
      <rect x="7" y="19" width="10" height="10" rx="1" />
      <path d="M17 21l21 -9" />
      <path d="M17 27l21 9" />
      <path d="M38 12v24" />
      <circle cx="30" cy="24" r="2.3" />
    </>
  )}

  {name === 'field' && (
    <>
      <path d="M6 32c8 3 12 3 18 0s10 -3 18 0" />
      <path d="M14 30v-6m0 6-3-3m3 3 3-3" />
      <path d="M24 27v-7m0 7-3.5-3m3.5 3 3.5-3" />
      <path d="M34 30v-6m0 6-3-3m3 3 3-3" />
    </>
  )}

  {name === 'spark' && (
    <>
      <circle cx="24" cy="24" r="4" />
      <path d="M24 20V9" /><circle cx="24" cy="8" r="1.8" />
      <path d="M27.2 21.4 35.5 13.4" /><circle cx="37" cy="12" r="1.8" />
      <path d="M27 27l7 8" /><circle cx="35" cy="36.5" r="1.8" />
      <path d="M20.5 26l-8 7" /><circle cx="11" cy="34" r="1.8" />
    </>
  )}

  {name === 'statemachine' && (
    <>
      <path d="M4 26h3" />
      <circle cx="12" cy="26" r="5" />
      <circle cx="24" cy="26" r="5" />
      <circle cx="36" cy="26" r="5" />
      <path d="M17 26h2.5" /><path d="M17.8 24.6 20 26l-2.2 1.4" />
      <path d="M29 26h2.5" /><path d="M29.8 24.6 32 26l-2.2 1.4" />
      <path d="M24 21c-6-6 6-6 0 0" />
    </>
  )}

  {name === 'node' && (
    <>
      <rect x="7" y="19" width="12" height="8" rx="1" />
      <rect x="29" y="9" width="12" height="8" rx="1" />
      <rect x="29" y="29" width="12" height="8" rx="1" />
      <path d="M19 23h6v-10h4" />
      <path d="M19 23h6v10h4" />
      <circle cx="25" cy="23" r="1.1" fill="currentColor" stroke="none" />
    </>
  )}

  {name === 'trajectory' && (
    <>
      <path d="M8 36C16 14 30 40 40 12" stroke-dasharray="3 3.5" />
      <circle cx="8" cy="36" r="2.4" />
      <circle cx="40" cy="12" r="2.4" />
      <path d="M22.5 25.5v3M21 27h3" />
    </>
  )}

  {name === 'arm' && (
    <>
      <path d="M9 39h12" />
      <circle cx="15" cy="38" r="1.7" />
      <path d="M15 38 25 22" />
      <circle cx="25" cy="22" r="1.7" />
      <path d="M25 22 38 17" />
      <path d="M38 17l3.5-2M38 17l1.5 4" />
    </>
  )}

  {name === 'coordframe' && (
    <>
      <path d="M10 38V9" /><path d="M7.5 12 10 8l2.5 4" />
      <path d="M10 38h29" /><path d="M36 35.5 40 38l-4 2.5" />
      <path d="M10 38 29 25" /><path d="M26 24.5l3.5 .5-1 3.4" />
    </>
  )}
</svg>

<style>
  .line-icon { width: 100%; height: 100%; display: block; }
</style>
