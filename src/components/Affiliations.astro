---
import { affiliationGroups } from '../data/site';
---

<section class="section affiliations">
  <div class="container">
    <div class="aff-groups">
      {affiliationGroups.map((g) => (
        <div class="aff-group">
          <span class="aff-cat">{g.label}</span>
          <div class="aff-pills">
            {g.items.map((it) => (
              <div class="aff-pill">
                {it.logo ? (
                  <span class="aff-chip"><img class="aff-logo" src={it.logo} alt={it.name} loading="lazy" /></span>
                ) : (
                  <span class="aff-mark" aria-hidden="true">{it.name.slice(0, 1)}</span>
                )}
                <span class="aff-name">{it.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .aff-groups { display: grid; gap: 0; }
  .aff-group {
    display: grid; grid-template-columns: 150px 1fr; gap: clamp(16px, 3vw, 44px);
    align-items: center;
    padding: clamp(18px, 2.4vw, 26px) 0;
    border-top: 1px solid var(--color-hairline);
  }
  .aff-group:last-child { border-bottom: 1px solid var(--color-hairline); }
  .aff-cat {
    font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-accent);
  }
  .aff-pills { display: flex; flex-wrap: wrap; gap: 12px; }
  .aff-pill {
    display: inline-flex; align-items: center; gap: 11px;
    padding: 8px 20px 8px 8px; border-radius: var(--radius-full);
    border: 1px solid var(--color-border); background: var(--color-surface);
    transition: border-color 0.2s var(--ease);
  }
  .aff-pill:hover { border-color: var(--color-blue); }
  /* light chip holds each logo so colored + transparent logos read cleanly */
  .aff-chip {
    width: 40px; height: 40px; flex: none; border-radius: 8px;
    background: #f3f1ea; display: grid; place-items: center; padding: 5px;
  }
  .aff-logo {
    max-width: 100%; max-height: 100%; width: auto; object-fit: contain; display: block;
  }
  .aff-mark {
    width: 40px; height: 40px; border-radius: 8px; flex: none;
    display: grid; place-items: center;
    font-family: var(--font-mono); font-weight: 700; font-size: 1.15rem; color: var(--color-ink-text);
    background: #f3f1ea;
  }
  .aff-name {
    font-family: var(--font-mono); font-size: 0.98rem; letter-spacing: 0.02em;
    color: var(--color-text); white-space: nowrap;
  }

  @media (max-width: 620px) {
    .aff-group { grid-template-columns: 1fr; gap: 12px; }
    .aff-cat { color: var(--color-accent); }
  }
</style>
