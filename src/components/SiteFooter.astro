---
import { site } from '../data/site';
const year = 2026; // static; bump at build if desired
---

<footer class="site-foot">
  <div class="container foot-grid">
    <div class="foot-brand">
      <a class="brand" href="/">CHANDRAN</a>
      <p class="foot-tag">{site.role} · {site.location}</p>
    </div>

    <nav class="foot-nav" aria-label="Footer">
      <a href="/work">Work</a>
      <a href="/journey">Journey</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="foot-social">
      <a href={site.links.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a>
      <a href={`mailto:${site.email}`}>Email ↗</a>
      <a href={site.links.github} target="_blank" rel="noopener">GitHub ↗</a>
      <a href={site.links.huggingface} target="_blank" rel="noopener">Hugging Face ↗</a>
    </div>
  </div>

  <div class="container foot-base">
    <span>© {year} {site.name}</span>
    <span class="mono-dim">Built with Astro · designed in the open</span>
  </div>
</footer>

<style>
  .site-foot { border-top: 1px solid var(--color-border); padding-block: clamp(40px, 6vh, 72px) 28px; margin-top: clamp(40px, 8vh, 120px); }
  .foot-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 32px; align-items: start; }
  .brand { font-family: var(--font-mono); font-weight: 700; font-size: 1.3rem; letter-spacing: 0.22em; }
  .foot-tag { color: var(--color-text-muted); margin-top: 10px; font-size: var(--text-sm); }
  .foot-nav, .foot-social { display: flex; flex-direction: column; gap: 12px; }
  .foot-nav a, .foot-social a { color: var(--color-text-muted); font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.06em; transition: color 0.2s; }
  .foot-nav a:hover, .foot-social a:hover { color: var(--color-text); }
  .foot-base { display: flex; justify-content: space-between; gap: 16px; margin-top: clamp(40px, 6vh, 72px); padding-top: 24px; border-top: 1px solid var(--color-border); color: var(--color-text-muted); font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.06em; }
  .mono-dim { opacity: 0.7; }
  @media (max-width: 760px) {
    .foot-grid { grid-template-columns: 1fr 1fr; }
    .foot-brand { grid-column: 1 / -1; }
    .foot-base { flex-direction: column; }
  }
</style>
