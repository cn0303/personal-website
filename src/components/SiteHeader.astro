---
// Persistent site header (PLAT-01). Wordmark = "CHANDRAN" (sketch 002, W3).
const links = [
  { label: 'Work', href: '/work' },
  { label: 'Journey', href: '/journey' },
  { label: 'About', href: '/about' },
];
---

<header class="site-head" data-header>
  <a class="brand" href="/">CHANDRAN</a>

  <nav class="nav-links" aria-label="Primary">
    {links.map((l) => <a class="link" href={l.href}>{l.label}</a>)}
    <a class="pill" href="/contact">Get in touch</a>
  </nav>

  <button class="menu-btn" aria-expanded="false" aria-controls="mobile-panel" data-menu-btn>
    ☰ Menu
  </button>
</header>

<nav class="mobile-panel" id="mobile-panel" aria-label="Primary mobile" data-mobile-panel>
  {links.map((l) => <a href={l.href}>{l.label}</a>)}
  <a class="pill" href="/contact">Get in touch</a>
</nav>

<style>
  .site-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .brand {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(1.4rem, 1rem + 1.4vw, 2.1rem);
    letter-spacing: 0.22em;
  }
  .nav-links { display: flex; align-items: center; gap: clamp(24px, 2.4vw, 44px); }
  .nav-links .link {
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-links .link:hover { color: var(--color-text); }

  .menu-btn {
    display: none;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: 10px;
    padding: 12px 15px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
  }

  .mobile-panel { display: none; flex-direction: column; gap: 4px; padding-top: 10px; }
  .mobile-panel a {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 13px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .mobile-panel .pill { margin-top: 14px; align-self: flex-start; border-bottom: none; }
  .mobile-panel.open { display: flex; }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .menu-btn { display: inline-block; }
  }
</style>

<script>
  const btn = document.querySelector('[data-menu-btn]');
  const panel = document.querySelector('[data-mobile-panel]');
  btn?.addEventListener('click', () => {
    const open = panel?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(!!open));
  });
</script>
