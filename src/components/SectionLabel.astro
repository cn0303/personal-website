---
/*
  SectionLabel — a quiet section header:
    01  CURRENT FOCUS  ————————————————————————————————
  Index in orange, label mono, a hairline ruler filling the row.
*/
interface Props {
  index: string;
  label: string;
}
const { index, label } = Astro.props;
---

<div class="section-label">
  <span class="sl-index">{index}</span>
  <span class="sl-text">{label}</span>
  <span class="sl-rule"></span>
</div>

<style>
  .section-label {
    display: flex; align-items: center; gap: 14px;
    font-family: var(--font-mono); font-size: var(--text-sm);
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: clamp(28px, 4vw, 48px);
  }
  .sl-index { color: var(--color-accent); flex: none; }
  .sl-text { color: var(--color-text-muted); flex: none; }
  .sl-rule { flex: 1 1 auto; height: 1px; background: var(--color-hairline); }
  @media (max-width: 560px) { .section-label { gap: 10px; } }
</style>
