---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Chandran Nandkumar - Robotics & AI Engineer',
  description = 'Robotics and AI engineer building toward trustworthy embodied intelligence: robot learning, real-world autonomy, interpretability, and human supervision.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OG / social (QUAL-03) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Fonts: Merriweather · Satoshi (Fontshare) · JetBrains Mono.
         TODO (asset phase): self-host as .woff2 via Astro Fonts API for perf/CWV. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
