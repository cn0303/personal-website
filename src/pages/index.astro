---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout>
  <section class="hero">
    <!-- LEFT: header + headline -->
    <div class="left">
      <SiteHeader />

      <div class="headline-block">
        <span class="kicker">01 — Embodied Intelligence</span>
        <!-- TODO (Phase 1 / content): replace with Chandran's real manifesto + bets copy -->
        <h1>Teaching machines to <em>understand</em> the physical world.</h1>
        <p class="lede">
          Engineer &amp; researcher building the perception, control, and learning systems
          that let robots act in the real world.
        </p>
        <div class="cta-row">
          <a class="pill" href="/work">See the work →</a>
          <a class="pill ghost" href="/thesis">Read the thesis</a>
        </div>
      </div>
    </div>

    <!-- RIGHT: cinematic visual, bleeds to edge.
         TODO (asset phase): replace placeholder with Chandran's teleop/field footage. -->
    <div class="visual" aria-hidden="true">
      <div class="grid"></div>
      <div class="glow"></div>
      <div class="frame">
        <span class="corner tl"></span><span class="corner tr"></span>
        <span class="corner bl"></span><span class="corner br"></span>
        <div class="readout">PERCEPTION&nbsp;&nbsp;<b>online</b><br />TORQUE&nbsp;&nbsp;12.4 Nm<br />POLICY&nbsp;&nbsp;v2.3</div>
        <svg class="arm" viewBox="0 0 360 340">
          <rect class="base" x="150" y="288" width="84" height="30" rx="6"></rect>
          <line class="ln" x1="192" y1="296" x2="120" y2="178"></line>
          <line class="ln" x1="120" y1="178" x2="236" y2="104"></line>
          <line class="ln" x1="236" y1="104" x2="292" y2="120"></line>
          <line class="ln" x1="292" y1="120" x2="300" y2="146"></line>
          <line class="ln" x1="292" y1="120" x2="316" y2="112"></line>
          <circle class="jt" cx="192" cy="296" r="12"></circle>
          <circle class="jt" cx="120" cy="178" r="11"></circle>
          <circle class="jt" cx="236" cy="104" r="10"></circle>
          <circle class="nd" cx="300" cy="146" r="5"></circle>
        </svg>
        <span class="label">[ FULL-BLEED FILM / TELEOP FOOTAGE GOES HERE ]</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1.06fr 0.94fr;
    align-items: stretch;
    background:
      radial-gradient(90% 120% at 12% 0%, rgba(214, 73, 46, 0.1), transparent 55%),
      linear-gradient(180deg, #0a0b0d, #0d0f12);
  }

  /* left column */
  .left {
    display: flex;
    flex-direction: column;
    padding: clamp(28px, 3vw, 44px) clamp(48px, 6vw, 120px) clamp(40px, 5vh, 80px) var(--gutter);
  }
  .headline-block { margin-top: auto; margin-bottom: auto; }
  h1 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--display);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin: 14px 0 clamp(20px, 3vh, 32px);
  }
  h1 em { font-family: var(--font-serif); font-style: italic; font-weight: 300; }
  .lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 42ch;
    line-height: 1.5;
    margin-bottom: clamp(26px, 4vh, 40px);
  }
  .cta-row { display: flex; gap: 14px; flex-wrap: wrap; }

  /* right cinematic visual */
  .visual {
    position: relative;
    overflow: hidden;
    border-left: 1px solid var(--color-border);
    background: linear-gradient(160deg, #0e1014, #08090b);
  }
  .grid {
    position: absolute; inset: 0; opacity: 0.6;
    background-image:
      linear-gradient(var(--color-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-grid) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(120% 90% at 60% 40%, #000, transparent 80%);
  }
  .glow {
    position: absolute; width: 60%; height: 60%; top: 8%; right: -8%; border-radius: 50%;
    background: radial-gradient(circle, rgba(214, 73, 46, 0.16), transparent 65%);
    filter: blur(20px);
  }
  .frame {
    position: absolute; inset: clamp(36px, 5vw, 84px);
    border: 1px solid var(--color-border); border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255, 255, 255, 0.015);
  }
  .corner { position: absolute; width: 22px; height: 22px; border: 2px solid var(--color-text-muted); opacity: 0.6; }
  .corner.tl { top: -1px; left: -1px; border-right: none; border-bottom: none; }
  .corner.tr { top: -1px; right: -1px; border-left: none; border-bottom: none; }
  .corner.bl { bottom: -1px; left: -1px; border-right: none; border-top: none; }
  .corner.br { bottom: -1px; right: -1px; border-left: none; border-top: none; }
  .label { position: absolute; bottom: 18px; left: 18px; font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.16em; color: var(--color-text-muted); }
  .readout { position: absolute; top: 18px; right: 18px; text-align: right; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--color-text-muted); line-height: 1.9; }
  .readout b { color: var(--color-accent); font-weight: 500; }
  .arm { width: 62%; height: auto; opacity: 0.92; }
  .arm .ln { fill: none; stroke: var(--color-text); stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
  .arm .jt { fill: #0d0f12; stroke: var(--color-text); stroke-width: 3; }
  .arm .nd { fill: var(--color-accent); }
  .arm .base { fill: rgba(255, 255, 255, 0.04); stroke: var(--color-text); stroke-width: 3; }

  /* ───────── responsive ───────── */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .visual { order: -1; min-height: 42vh; border-left: none; border-bottom: 1px solid var(--color-border); }
    .arm { width: 46%; }
    .left { padding-top: clamp(24px, 4vh, 40px); }
    .headline-block { margin: 0; padding: clamp(28px, 6vh, 56px) 0; }
    h1 { font-size: clamp(2.8rem, 9vw, 4.6rem); }
  }
  @media (max-width: 520px) {
    .frame { inset: 18px; }
    .arm { width: 52%; }
    .readout { font-size: 0.6rem; }
  }
</style>
