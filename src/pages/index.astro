---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Affiliations from '../components/Affiliations.astro';
import { site, bets, projects } from '../data/site';

const featured = projects.slice(0, 3);
---

<BaseLayout>
  <!-- ───────── HERO ───────── -->
  <section class="hero">
    <div class="left">
      <SiteHeader />
      <div class="headline-block">
        <span class="kicker">Robotics & AI Engineer · Incoming at Lely</span>
        <h1>Building real robots. Betting on <em>steerable</em> embodied AI.</h1>
        <p class="lede">{site.lede}</p>
        <div class="cta-row">
          <a class="pill" href="/work">See the work →</a>
          <a class="pill ghost" href="/about">About me</a>
        </div>
      </div>
    </div>

    <!-- cinematic hero video slideshow (real footage) -->
    <div class="visual">
      <div class="hero-slides" data-hero>
        <video class="hero-video active" muted playsinline preload="auto" poster="/media/irl-pickup-poster.png"><source src="/media/hero.mp4" type="video/mp4" /></video>
        <video class="hero-video" muted playsinline preload="none" poster="/media/forgis-poster.png"><source src="/media/forgis-demo.mp4" type="video/mp4" /></video>
        <video class="hero-video" muted playsinline preload="none"><source src="/media/hero3.mp4" type="video/mp4" /></video>
      </div>
      <div class="visual-grad"></div>
      <span class="corner tl"></span><span class="corner tr"></span>
      <span class="corner bl"></span><span class="corner br"></span>
      <span class="timecode" data-tc>● ALPINE VALLEY · FIELD</span>
      <div class="slot-caption" data-caption>
        <span class="sc-kick">Independent research direction</span>
        <span class="sc-main">VLA supervision + steering</span>
        <span class="sc-sub">SO-101 · SmolVLA · Alpine Valley</span>
      </div>
      <div class="hero-dots" data-dots>
        <button type="button" class="on" aria-label="Clip 1: Alpine Valley"></button>
        <button type="button" aria-label="Clip 2: FORGIS hackathon"></button>
        <button type="button" aria-label="Clip 3: interpretability"></button>
      </div>
    </div>
  </section>

  <!-- ───────── BETS ───────── -->
  <section class="section bets">
    <div class="container">
      <span class="eyebrow">What I'm betting on</span>
      <div class="bets-grid">
        {bets.map((b) => (
          <div class="bet">
            <span class="bet-n">{b.n}</span>
            <h2 class="bet-title">{b.title}</h2>
            <p class="bet-body">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────── SELECTED WORK ───────── -->
  <section class="section work-preview">
    <div class="container">
      <div class="sec-head">
        <div>
          <span class="eyebrow">Selected work</span>
          <h2 class="section-title">Evidence for the thesis, not a trophy shelf.</h2>
        </div>
        <a class="pill ghost" href="/work">All work →</a>
      </div>
      <div class="cards-3">
        {featured.map((p) => <ProjectCard project={p} />)}
      </div>
    </div>
  </section>

  <Affiliations />
  <SiteFooter />
</BaseLayout>

<script>
  // Hero video slideshow: play each clip, crossfade to the next on end. Dots jump.
  const root = document.querySelector('[data-hero]');
  if (root) {
    const slides = Array.from(root.querySelectorAll('video'));
    const dots = Array.from(document.querySelectorAll('[data-dots] button'));
    const cap = document.querySelector('[data-caption]');
    const tc = document.querySelector('[data-tc]');
    const captions = [
      { kick: 'Independent research direction', main: 'VLA supervision + steering', sub: 'SO-101 · SmolVLA · Alpine Valley', tc: '● ALPINE VALLEY · FIELD' },
      { kick: 'Physical AI Hackathon · 1st place', main: 'Vision-guided pick & place', sub: 'Dobot Nova 5 · FORGIS, Zurich', tc: '● FORGIS · ZURICH' },
      { kick: 'Research & experiments', main: 'Embodied AI, up close', sub: 'SO-101 · VLA · teleoperation', tc: '● LAB · SO-101' },
    ];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let idx = 0;
    function show(i: number) {
      slides.forEach((v, k) => v.classList.toggle('active', k === i));
      dots.forEach((d, k) => d.classList.toggle('on', k === i));
      const c = captions[i];
      if (cap && c) {
        const k = cap.querySelector('.sc-kick'); if (k) k.textContent = c.kick;
        const m = cap.querySelector('.sc-main'); if (m) m.textContent = c.main;
        const s = cap.querySelector('.sc-sub'); if (s) s.textContent = c.sub;
      }
      if (tc && c) tc.textContent = c.tc;
    }
    function play(i: number) {
      idx = i;
      const v = slides[i];
      show(i);
      try { v.currentTime = 0; } catch (e) {}
      const p = v.play();
      if (p && p.catch) p.catch(() => {});
    }
    slides.forEach((v) => v.addEventListener('ended', () => play((idx + 1) % slides.length)));
    dots.forEach((d, k) => d.addEventListener('click', () => play(k)));
    if (reduce) { show(0); } else { play(0); }
  }
</script>

<style>
  /* ───────── hero ───────── */
  .hero {
    position: relative; min-height: 100vh; display: grid;
    grid-template-columns: 1.06fr 0.94fr; align-items: stretch;
    background:
      radial-gradient(90% 120% at 12% 0%, rgba(214, 73, 46, 0.1), transparent 55%),
      linear-gradient(180deg, #0a0b0d, #0d0f12);
  }
  .left { display: flex; flex-direction: column; padding: clamp(28px, 3vw, 44px) clamp(48px, 6vw, 120px) clamp(40px, 5vh, 80px) var(--gutter); }
  .headline-block { margin-top: auto; margin-bottom: auto; }
  h1 { font-family: var(--font-sans); font-weight: 700; font-size: var(--display); line-height: 0.98; letter-spacing: -0.03em; margin: 14px 0 clamp(20px, 3vh, 32px); }
  h1 em { font-family: var(--font-serif); font-style: italic; font-weight: 300; }
  .lede { font-size: var(--text-lg); color: var(--color-text-muted); max-width: 44ch; line-height: 1.5; margin-bottom: clamp(26px, 4vh, 40px); }
  .cta-row { display: flex; gap: 14px; flex-wrap: wrap; }

  /* cinematic hero video */
  .visual { position: relative; overflow: hidden; border-left: 1px solid var(--color-border); background: #06070a; }
  .hero-slides { position: absolute; inset: 0; }
  .hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.8s var(--ease); }
  .hero-video.active { opacity: 1; }
  .hero-dots { position: absolute; left: 0; right: 0; bottom: 26px; display: flex; gap: 8px; justify-content: center; z-index: 3; }
  .hero-dots button { width: 8px; height: 8px; border-radius: 50%; border: none; background: rgba(243, 241, 234, 0.4); cursor: pointer; padding: 0; transition: all 0.25s var(--ease); }
  .hero-dots button.on { background: var(--color-accent); width: 22px; border-radius: 4px; }
  .visual-grad { position: absolute; inset: 0; pointer-events: none; background: linear-gradient(180deg, rgba(10,11,13,0.10) 0%, rgba(10,11,13,0.15) 55%, rgba(10,11,13,0.70) 100%); }
  .corner { position: absolute; width: 22px; height: 22px; border: 2px solid rgba(243,241,234,0.55); }
  .corner.tl { top: 22px; left: 22px; border-right: none; border-bottom: none; }
  .corner.tr { top: 22px; right: 22px; border-left: none; border-bottom: none; }
  .corner.bl { bottom: 22px; left: 22px; border-right: none; border-top: none; }
  .corner.br { bottom: 22px; right: 22px; border-left: none; border-top: none; }
  .timecode { position: absolute; top: 24px; right: 30px; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.14em; color: #f3f1ea; text-shadow: 0 1px 4px rgba(0,0,0,0.6); }
  .slot-caption { position: absolute; left: 34px; bottom: 34px; display: flex; flex-direction: column; gap: 8px; text-shadow: 0 1px 6px rgba(0,0,0,0.7); }
  .sc-kick { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-accent); }
  .sc-main { font-family: var(--font-serif); font-size: clamp(1.2rem, 0.9rem + 1vw, 1.7rem); color: #f3f1ea; }
  .sc-sub { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.06em; color: rgba(243,241,234,0.82); }

  /* ───────── bets ───────── */
  .bets-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(24px, 3vw, 56px); margin-top: 12px; }
  .bet-n { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-accent); letter-spacing: 0.1em; }
  .bet-title { font-family: var(--font-serif); font-weight: 400; font-size: clamp(1.4rem, 1.1rem + 1vw, 2rem); margin: 14px 0 14px; line-height: 1.15; }
  .bet-body { color: var(--color-text-muted); line-height: 1.6; }

  /* ───────── work preview ───────── */
  .sec-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: clamp(32px, 4vw, 56px); }
  .cards-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

  /* ───────── responsive ───────── */
  @media (max-width: 980px) {
    .bets-grid { grid-template-columns: 1fr; gap: 32px; }
    .cards-3 { grid-template-columns: 1fr; }
  }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .visual { order: -1; min-height: 44vh; border-left: none; border-bottom: 1px solid var(--color-border); }
    .left { padding-top: clamp(24px, 4vh, 40px); }
    .headline-block { margin: 0; padding: clamp(28px, 6vh, 56px) 0; }
    h1 { font-size: clamp(2.8rem, 9vw, 4.6rem); }
    .sec-head { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 520px) {
    .frame { inset: 18px; }
    .slot-caption { left: 18px; bottom: 38px; }
    .scrubber { left: 18px; right: 18px; }
  }
</style>
