---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../data/site';
---

<PageLayout title="Contact - Chandran Nandkumar" description="Get in touch about robotics, embodied AI, interpretability, steerability, and technical writing.">
  <section class="container page-top contact">
    <span class="eyebrow">Contact</span>
    <h1 class="page-title">Let’s talk about<br /><em>machines that move.</em></h1>
    <p class="lead">
      Open to research conversations, robotics collaborations, open-source work, and technical writing
      around embodied AI, robot learning, interpretability, steerability, and real-world autonomy. The
      fastest way to reach me is email or LinkedIn.
    </p>

    <div class="channels">
      <a class="channel" href={`mailto:${site.email}`}>
        <span class="ch-label">Email</span>
        <span class="ch-value">{site.email}</span>
        <span class="ch-arrow">↗</span>
      </a>
      <a class="channel" href={site.links.linkedin} target="_blank" rel="noopener">
        <span class="ch-label">LinkedIn</span>
        <span class="ch-value">/in/chandran-nandkumar</span>
        <span class="ch-arrow">↗</span>
      </a>
      <a class="channel" href={site.links.github} target="_blank" rel="noopener">
        <span class="ch-label">GitHub</span>
        <span class="ch-value">github.com/cn0303</span>
        <span class="ch-arrow">↗</span>
      </a>
      <a class="channel" href={site.links.huggingface} target="_blank" rel="noopener">
        <span class="ch-label">Hugging Face</span>
        <span class="ch-value">Read writing &amp; robotics work</span>
        <span class="ch-arrow">↗</span>
      </a>
    </div>

    <p class="loc">Based in {site.location}.</p>
  </section>
</PageLayout>

<style>
  .contact { padding-bottom: clamp(60px, 12vh, 160px); }
  .page-title { margin: 18px 0 28px; }
  .lead { margin-bottom: clamp(40px, 6vh, 72px); }

  .channels { display: grid; gap: 0; border-top: 1px solid var(--color-border); max-width: 820px; }
  .channel {
    display: grid; grid-template-columns: 160px 1fr auto; align-items: center; gap: 20px;
    padding: clamp(20px, 3vh, 32px) 4px; border-bottom: 1px solid var(--color-border);
    transition: padding-left 0.25s var(--ease), color 0.2s;
  }
  .channel:hover { padding-left: 16px; }
  .ch-label { font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-text-muted); }
  .ch-value { font-family: var(--font-serif); font-size: clamp(1.3rem, 1rem + 1.4vw, 2.2rem); }
  .ch-arrow { color: var(--color-accent); font-family: var(--font-mono); }
  .loc { margin-top: 40px; font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-text-muted); }

  @media (max-width: 640px) {
    .channel { grid-template-columns: 1fr auto; }
    .ch-label { grid-column: 1 / -1; }
  }
</style>
