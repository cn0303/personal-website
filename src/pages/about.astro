---
import PageLayout from '../layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import { skills, education } from '../data/site';
import portrait from '../assets/brand/portrait.jpg';
---

<PageLayout title="About - Chandran Nandkumar" description="Robotics and AI engineer building real systems while betting on interpretable, steerable embodied AI.">
  <section class="container page-top about-hero">
    <div>
      <span class="eyebrow">About</span>
      <h1 class="page-title">Robotics engineer with<br /><em>a research bet.</em></h1>
      <div class="portrait">
        <Image src={portrait} alt="Chandran Nandkumar" widths={[480, 900]} sizes="(max-width: 900px) 90vw, 42vw" />
      </div>
    </div>
    <div class="bio">
      <p>
        I am a robotics and AI engineer with an MSc in Robotics from <strong>TU Delft</strong> and a
        mechanical engineering foundation from <strong>NITK Surathkal</strong>. Professionally, I have worked
        on real-world robot autonomy at <strong>Qafka Robotics</strong>, and I am joining
        <strong>Lely</strong> as a Rapid Prototyping Engineer.
      </p>
      <p>
        My independent bet is narrower and more research-driven: embodied foundation models need the
        reliability and fine-grained control that made classical robotics useful in industry. VLAs and
        world models are exciting, but they need to become interpretable and steerable before people can
        trust them in unstructured environments.
      </p>
      <p>
        That is the thread through my work: HRI at TU Delft, deployment instincts at Qafka, the Alpine
        Valley pivot into VLA interpretability, open-source robotics tooling, and technical writing. I am
        not trying to look like an agri-tech founder or a generic AI app builder. I am building evidence
        for a long-term direction: robot intelligence that humans can understand, correct, steer, and rely on.
      </p>
    </div>
  </section>

  <section class="section container kit">
    <div class="kit-col">
      <span class="eyebrow">Focus</span>
      <ul class="kit-list">
        {skills.focus.map((f) => <li>{f}</li>)}
      </ul>
    </div>
    <div class="kit-col">
      <span class="eyebrow">Software & platforms</span>
      <div class="tag-row">
        {skills.software.map((s) => <span class="tag">{s}</span>)}
      </div>
    </div>
    <div class="kit-col">
      <span class="eyebrow">Strengths</span>
      <ul class="kit-list">
        {skills.competencies.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <section class="section container edu">
    <span class="eyebrow">Education</span>
    {education.map((e) => (
      <div class="edu-row">
        <h2 class="edu-school">{e.school}</h2>
        <p class="edu-degree">{e.degree}</p>
        <span class="edu-years">{e.years}</span>
      </div>
    ))}
  </section>

  <section class="section container cta-band">
    <h2 class="section-title">Want to talk robotics, autonomy, interpretability, or steerability?</h2>
    <a class="pill" href="/contact">Get in touch →</a>
  </section>
</PageLayout>

<style>
  .about-hero { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 5vw, 80px); align-items: start; padding-bottom: clamp(40px, 6vh, 80px); }
  .page-title { margin-top: 18px; }
  .portrait { margin-top: clamp(28px, 4vw, 44px); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; aspect-ratio: 4 / 5; background: #06070a; }
  .portrait :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .bio p { color: var(--color-text-muted); line-height: 1.7; margin-bottom: 18px; font-size: var(--text-lg); }
  .bio strong { color: var(--color-text); font-weight: 500; }

  .kit { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(28px, 4vw, 64px); }
  .kit-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; }
  .kit-list li { padding-left: 20px; position: relative; line-height: 1.4; }
  .kit-list li::before { content: '—'; position: absolute; left: 0; color: var(--color-accent); }

  .edu-row { padding: 22px 0; border-bottom: 1px solid var(--color-border); }
  .edu-row:first-of-type { border-top: 1px solid var(--color-border); margin-top: 24px; }
  .edu-school { font-family: var(--font-serif); font-weight: 400; font-size: clamp(1.3rem, 1rem + 1vw, 1.9rem); }
  .edu-degree { color: var(--color-text-muted); margin-top: 8px; }
  .edu-years { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-muted); margin-top: 8px; display: inline-block; }

  .cta-band { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .about-hero { grid-template-columns: 1fr; }
    .kit { grid-template-columns: 1fr; }
  }
</style>
