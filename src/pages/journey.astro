---
import PageLayout from '../layouts/PageLayout.astro';
import { timeline } from '../data/site';

const kindLabel: Record<string, string> = {
  education: 'Education',
  work: 'Work',
  award: 'Award / Win',
  project: 'Project',
  research: 'Research',
};

// Logos keyed by the entry's org string (stable, survives reordering).
const orgLogos: Record<string, string> = {
  'NITK Surathkal': '/logos/journey/nitk.png',
  'IEEE ICDTMRA': '/logos/journey/ieee.png',
  Hackster: '/logos/journey/hackster.png',
  'MSc Robotics': '/logos/journey/tudelft.png',
  'TU Delft / Frontiers': '/logos/journey/frontiers.png',
  'Solo product': '/logos/journey/unspool.png',
  'Robotics & AI Engineer': '/logos/qafka.jpg',
  'Founder in Residence': '/logos/alpinevalley.svg',
  'FORGIS / Snap / Junction': '/logos/journey/junction.png',
  'Hugging Face': '/logos/journey/huggingface.png',
  'Hugging Face open source': '/logos/journey/huggingface.png',
  'Rapid Prototyping Engineer': '/logos/journey/lely.png',
};
---

<PageLayout title="Journey - Chandran Nandkumar" description="The chronological trajectory - education, research, work, and wins.">
  <section class="container page-top page-intro">
    <span class="eyebrow">Journey</span>
    <h1 class="page-title">How I got <em>here.</em></h1>
    <p class="lead">
      A forward-chronological trajectory, from a mechanical-engineering undergrad and a single-propeller UAV,
      through a robotics master’s at TU Delft, to embodied-AI research, a string of hackathon wins, and building
      agritech robots in a castle in Austria.
    </p>
  </section>

  <section class="container timeline-wrap">
    <ol class="timeline">
      {timeline.map((e) => {
        const logo = e.org ? orgLogos[e.org] : undefined;
        return (
          <li class={`tl-item kind-${e.kind}`}>
            <div class="tl-year">{e.year}</div>
            <div class="tl-dot" aria-hidden="true"></div>
            <div class="tl-body">
              <div class="tl-head">
                {logo && <img class="tl-logo" src={logo} alt={e.org} loading="lazy" width="44" height="44" />}
                <span class="tl-kind">{kindLabel[e.kind]}</span>
              </div>
              <h2 class="tl-title">{e.title}</h2>
              {e.org && <p class="tl-org">{e.org}</p>}
              {e.body && <p class="tl-text">{e.body}</p>}
              {e.link && (
                <a class="tl-link" href={e.link.href} target="_blank" rel="noopener">{e.link.label} ↗</a>
              )}
            </div>
          </li>
        );
      })}
    </ol>
  </section>
</PageLayout>

<style>
  .page-intro { padding-bottom: clamp(36px, 5vh, 64px); }
  .page-title { margin: 18px 0 28px; }
  .timeline-wrap { padding-bottom: clamp(20px, 4vh, 60px); }

  .timeline { list-style: none; margin: 0; padding: 0; }
  .tl-item {
    display: grid;
    grid-template-columns: 96px 28px 1fr;
    gap: 0 20px;
    padding-bottom: clamp(28px, 4vh, 48px);
  }
  .tl-year { font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.04em; color: var(--color-text-muted); padding-top: 4px; text-align: right; }
  .tl-dot { position: relative; justify-self: center; width: 13px; height: 13px; border-radius: 50%; background: var(--color-bg); border: 2px solid var(--color-text-muted); margin-top: 6px; }
  .kind-award .tl-dot, .kind-work .tl-dot { border-color: var(--color-accent); background: var(--color-accent); }
  .tl-item:not(:last-child) .tl-dot::after {
    content: ''; position: absolute; left: 50%; top: 16px; transform: translateX(-50%);
    width: 2px; height: calc(100% + clamp(28px, 4vh, 48px)); background: var(--color-border);
  }

  .tl-head { display: flex; align-items: center; gap: 13px; }
  .tl-logo {
    width: 44px; height: 44px; border-radius: 9px; object-fit: contain;
    background: #f3f1ea; padding: 5px; flex: none;
  }
  .tl-kind { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-text-muted); }
  .tl-title { font-family: var(--font-sans); font-weight: 600; letter-spacing: -0.01em; font-size: clamp(1.25rem, 1rem + 0.8vw, 1.7rem); line-height: 1.2; margin: 12px 0 0; }
  .tl-org { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-text-muted); margin-top: 8px; }
  .tl-text { font-family: var(--font-serif); color: var(--color-text-muted); line-height: 1.55; margin-top: 12px; max-width: 64ch; }
  .tl-link { display: inline-block; margin-top: 14px; font-family: var(--font-mono); font-size: 0.82rem; color: var(--color-blue); border-bottom: 1px solid rgba(90, 162, 255, 0.4); padding-bottom: 2px; transition: border-color 0.2s var(--ease), color 0.2s var(--ease); }
  .tl-link:hover { color: #8bc0ff; border-bottom-color: var(--color-blue); }

  @media (max-width: 620px) {
    .tl-item { grid-template-columns: 20px 1fr; }
    .tl-year { grid-column: 2; text-align: left; padding-top: 0; margin-bottom: 6px; color: var(--color-accent); }
    .tl-dot { grid-row: 1 / 3; grid-column: 1; }
    .tl-body { grid-column: 2; }
  }
</style>
