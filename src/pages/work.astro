---
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/site';
---

<PageLayout title="Work - Chandran Nandkumar" description="Selected robotics, embodied AI, interpretability, steerability, and human-AI interface work.">
  <section class="container page-top page-intro">
    <span class="eyebrow">Work</span>
    <h1 class="page-title">Systems, studies, and<br /><em>interfaces for autonomy.</em></h1>
    <p class="lead">
      These are not meant to read as a generic project grid. They are receipts for a direction:
      real robots under physical constraints, embodied AI policies that need observability and
      steering handles, and interfaces that help humans understand complex systems.
    </p>
  </section>

  <section class="container work-list">
    {projects.map((p) => <ProjectCard project={p} detailed />)}
  </section>
</PageLayout>

<style>
  .page-intro { padding-bottom: clamp(40px, 6vh, 80px); }
  .page-title { margin: 18px 0 28px; }
  .work-list { display: grid; grid-template-columns: 1fr; gap: 20px; padding-bottom: clamp(20px, 4vh, 60px); }
  @media (min-width: 1100px) {
    .work-list { grid-template-columns: 1fr 1fr; }
  }
</style>
